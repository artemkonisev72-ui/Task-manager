generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  EXECUTOR
}

model User {
  id             String          @id @default(uuid())
  login          String          @unique
  passwordHash   String
  role           Role            @default(EXECUTOR)
  sessions       Session[]
  logisticsTasks LogisticsTask[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}


model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
}

model LogisticsTask {
  id          String   @id @default(uuid())
  number      String
  date        DateTime
  timeStart   String
  timeEnd     String
  address     String
  logistics   String
  dealContent String
  comment     String?
  checklist   String?
  amount      Float

  executors User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
